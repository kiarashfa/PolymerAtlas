    "common_monomers": [],
    "catalysts": [
      "sulfur"
    ],
    "industrial_process_notes": "Natural rubber is heated with sulfur (optimal content around 10% for general-purpose vulcanizates), forming sulfur crosslinks at allylic C-H sites adjacent to the polyisoprene double bonds. Shorter sulfur crosslinks give better heat resistance; longer polysulfidic crosslinks give better dynamic (flex) properties but less heat resistance. Charles Goodyear discovered the process accidentally in 1839 (rubber-sulfur mixture dropped on a hot stove) and patented it in 1844.",
    "synthesis_scheme_image": null
  },
